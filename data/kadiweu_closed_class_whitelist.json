{
  "metadata": {
    "name": "Kadiweu closed-class whitelist with UD defaults",
    "version": "0.1",
    "description": "Curated whitelist of Kadiwéu closed-class items for UD treebank work. Entries provide default lemma, UPOS, and feature templates. Surface forms may still require context-sensitive POS decisions, especially DET vs PRON and possessive uses.",
    "principles": [
      "Demonstrative forms are DET by default when nominal modifiers and PRON when headless.",
      "Possessive pronominal uses are PRON with Poss=Yes.",
      "Classifier/deictic morphology such as -jo, -ca, etc. is not encoded as UD features by default; store it in MISC if needed.",
      "Feature templates are defaults, not immutable analyses."
    ],
    "feature_encoding_policy": {
      "det_default": "PronType=Dem",
      "possessive_pronoun_default": "PronType=Prs|Poss=Yes",
      "classifier_storage": "MISC Clf=...",
      "number_policy": "Number is included when the form is transparently plural or when singular is the practical default in the treebank."
    }
  },
